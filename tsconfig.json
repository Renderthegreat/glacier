{
	"compilerOptions": {
		"target": "esnext",
		"jsx": "react-jsx",
		"jsxImportSource": "rynth",

		"module": "esnext",
		"moduleResolution": "bundler",

		"rootDirs": [
			"src",
			"tests",
		],
		"rootDir": ".",
		"paths": {
			"#~/*": [
				"./src/*.js",
			],
			"#tests/*": [
				"./tests/*.js",
			],
		},

		"resolveJsonModule": true,

		"outDir": "dist",

		"strict": true,
		"strictNullChecks": true,
		"skipLibCheck": true,

		"preserveSymlinks": true,
	},
}